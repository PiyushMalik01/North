._*

# Editor
.vscode/
.idea/
*.swp
*~
*.swo

# Node
node_modules/
*.log
npm-debug.log*
.npm/

# npm pack output
*.tgz

# Build artifact — installer/skill-source/ is regenerated from the parent
# files by `npm run bundle` (prepublishOnly hook). Source of truth is the
# parent SKILL.md, references/, templates/, projects/, README.md.
installer/skill-source/

# Brainstorm session cache (per-session, not source)
.superpowers/

# Playwright MCP logs (dev testing artifacts)
.playwright-mcp/

# Skills installed via `npx skills add` (symlinks to .agents/skills/)
.agents/

# Local test installs (the installer drops a .claude/ here when smoke-tested
# from the repo root)
.claude/

# Skills lock (auto-generated by npx skills add)
skills-lock.json

# Misc
.env
.env.local
*.tmp
